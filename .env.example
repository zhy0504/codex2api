# ============================================================
# Codex2API Docker 环境变量配置
# 复制此文件为 .env 并修改对应值
# ============================================================

# 运行环境（production / development）
# 生产部署建议 production，本地调试可改为 development
APP_ENV=production

# HTTP 服务端口
CODEX_PORT=8080

# Docker 镜像（docker-compose.yml 使用）
CODEX2API_IMAGE=ghcr.io/zhy0504/codex2api
CODEX2API_TAG=v0.0.0

# 管理后台密钥（生产环境必须配置）
ADMIN_SECRET=change-me-admin-secret

# 凭据加密密钥（生产环境必须配置，长度至少 32）
CREDENTIALS_ENCRYPTION_KEY=change-me-to-32-plus-characters-key

# 下游 API 密钥（逗号分隔，生产环境至少配置一个）
CODEX_API_KEYS=sk-your-key-1

# 允许跨域的来源（逗号分隔，可选；默认仅允许同源）
# CORS_ALLOWED_ORIGINS=http://localhost:5173,https://admin.example.com

# 全局代理（可选）
# CODEX_PROXY_URL=http://host.docker.internal:7890

# ---- PostgreSQL ----
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=codex2api
DATABASE_PASSWORD=codex2api
DATABASE_NAME=codex2api

# ---- Redis ----
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# ---- 时区 ----
TZ=Asia/Shanghai
